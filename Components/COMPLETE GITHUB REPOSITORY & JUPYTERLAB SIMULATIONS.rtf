  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "def magnet_field_cylinder(x, y, z, x0, y0, z0, R, L, Br):\\n",\par
    "    \\"\\"\\"\\n",\par
    "    Calculate B-field from cylindrical magnet at point (x,y,z).\\n",\par
    "    \\n",\par
    "    Parameters:\\n",\par
    "    -----------\\n",\par
    "    x, y, z : float - observation point coordinates (mm)\\n",\par
    "    x0, y0, z0 : float - magnet center coordinates (mm)\\n",\par
    "    R : float - magnet radius (mm)\\n",\par
    "    L : float - magnet length (mm)\\n",\par
    "    Br : float - remanence (Tesla)\\n",\par
    "    \\n",\par
    "    Returns:\\n",\par
    "    --------\\n",\par
    "    Bx, By, Bz : float - field components (Tesla)\\n",\par
    "    \\"\\"\\"\\n",\par
    "    # Convert to meters\\n",\par
    "    x = (x - x0) / 1000\\n",\par
    "    y = (y - y0) / 1000\\n",\par
    "    z = (z - z0) / 1000\\n",\par
    "    R = R / 1000\\n",\par
    "    L = L / 1000\\n",\par
    "    \\n",\par
    "    # Cylindrical coordinates\\n",\par
    "    rho = np.sqrt(x**2 + y**2)\\n",\par
    "    \\n",\par
    "    # Handle on-axis case\\n",\par
    "    if rho < 1e-10:\\n",\par
    "        # On-axis field\\n",\par
    "        z1 = z - L/2\\n",\par
    "        z2 = z + L/2\\n",\par
    "        Bz = (Br/2) * ((z2)/np.sqrt(z2**2 + R**2) - \\n",\par
    "                        (z1)/np.sqrt(z1**2 + R**2))\\n",\par
    "        return 0, 0, Bz\\n",\par
    "    \\n",\par
    "    # Off-axis (simplified - using equivalent surface currents)\\n",\par
    "    # This is approximate - for accurate results use FEMM\\n",\par
    "    alpha = R / rho\\n",\par
    "    \\n",\par
    "    # Integration over magnet surfaces\\n",\par
    "    z1 = z - L/2\\n",\par
    "    z2 = z + L/2\\n",\par
    "    \\n",\par
    "    k1_sq = (4*R*rho) / ((rho + R)**2 + z1**2)\\n",\par
    "    k2_sq = (4*R*rho) / ((rho + R)**2 + z2**2)\\n",\par
    "    \\n",\par
    "    # Avoid numerical issues\\n",\par
    "    k1_sq = np.clip(k1_sq, 0, 1)\\n",\par
    "    k2_sq = np.clip(k2_sq, 0, 1)\\n",\par
    "    \\n",\par
    "    # Complete elliptic integrals\\n",\par
    "    from scipy.special import ellipk, ellipe\\n",\par
    "    \\n",\par
    "    K1 = ellipk(k1_sq)\\n",\par
    "    E1 = ellipe(k1_sq)\\n",\par
    "    K2 = ellipk(k2_sq)\\n",\par
    "    E2 = ellipe(k2_sq)\\n",\par
    "    \\n",\par
    "    # Field components\\n",\par
    "    B_rho = (Br * R) / (2*np.pi) * (\\n",\par
    "        (alpha * (K2 - E2 * (1 - k2_sq/2) / (1 - k2_sq))) / np.sqrt((rho + R)**2 + z2**2) -\\n",\par
    "        (alpha * (K1 - E1 * (1 - k1_sq/2) / (1 - k1_sq))) / np.sqrt((rho + R)**2 + z1**2)\\n",\par
    "    )\\n",\par
    "    \\n",\par
    "    Bz = (Br * R) / (4*np.pi) * (\\n",\par
    "        (K2 + E2 * (alpha**2 - 1 - k2_sq/2) / ((1 - k2_sq) * alpha**2)) / np.sqrt((rho + R)**2 + z2**2) -\\n",\par
    "        (K1 + E1 * (alpha**2 - 1 - k1_sq/2) / ((1 - k1_sq) * alpha**2)) / np.sqrt((rho + R)**2 + z1**2)\\n",\par
    "    )\\n",\par
    "    \\n",\par
    "    # Convert to Cartesian\\n",\par
    "    if rho > 0:\\n",\par
    "        Bx = B_rho * (x/rho)\\n",\par
    "        By = B_rho * (y/rho)\\n",\par
    "    else:\\n",\par
    "        Bx = 0\\n",\par
    "        By = 0\\n",\par
    "    \\n",\par
    "    return Bx, By, Bz"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Calculate total field from all magnets\\n",\par
    "def total_field(x, y, z, positions, config):\\n",\par
    "    Bx_tot, By_tot, Bz_tot = 0, 0, 0\\n",\par
    "    R = config['magnet_diameter'] / 2\\n",\par
    "    L = config['magnet_thickness']\\n",\par
    "    Br = config['magnet_br']\\n",\par
    "    \\n",\par
    "    for (x0, y0, z0) in positions:\\n",\par
    "        Bx, By, Bz = magnet_field_cylinder(x, y, z, x0, y0, z0, R, L, Br)\\n",\par
    "        Bx_tot += Bx\\n",\par
    "        By_tot += By\\n",\par
    "        Bz_tot += Bz\\n",\par
    "    \\n",\par
    "    return Bx_tot, By_tot, Bz_tot"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 3. Field Map Generation"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Generate grid\\n",\par
    "x_range = np.linspace(-50, 50, 100)\\n",\par
    "y_range = np.linspace(-50, 50, 100)\\n",\par
    "z_range = np.linspace(0, 50, 50)\\n",\par
    "\\n",\par
    "# XY plane at z=6.35mm (magnet surface)\\n",\par
    "X, Y = np.meshgrid(x_range, y_range)\\n",\par
    "Bz_surface = np.zeros_like(X)\\n",\par
    "\\n",\par
    "for i in range(len(x_range)):\\n",\par
