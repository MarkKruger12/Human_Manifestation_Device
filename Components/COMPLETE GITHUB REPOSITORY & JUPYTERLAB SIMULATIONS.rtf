    paths:\par
      - 'notebooks/*.ipynb'\par
      - 'src/**'\par
\par
jobs:\par
  test-notebooks:\par
    runs-on: ubuntu-latest\par
    \par
    steps:\par
    - uses: actions/checkout@v3\par
    \par
    - name: Set up Python\par
      uses: actions/setup-python@v4\par
      with:\par
        python-version: '3.9'\par
    \par
    - name: Cache conda\par
      uses: actions/cache@v3\par
      env:\par
        CACHE_NUMBER: 0\par
      with:\par
        path: ~/conda_pkgs_dir\par
        key: $\{\{ runner.os \}\}-conda-$\{\{ env.CACHE_NUMBER \}\}-$\{\{ hashFiles('environment.yml') \}\}\par
    \par
    - name: Setup conda\par
      uses: conda-incubator/setup-miniconda@v2\par
      with:\par
        activate-environment: auric-replicator\par
        environment-file: environment.yml\par
        python-version: 3.9\par
        auto-activate-base: false\par
    \par
    - name: Execute notebooks\par
      shell: bash -l \{0\}\par
      run: |\par
