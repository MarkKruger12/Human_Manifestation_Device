## \f1\u-10179?\u-9005?\f2  \f0 NOTEBOOK 02: Resonance Analysis\par
\par
```python\par
\{\par
 "cells": [\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "# \f3\u9889?\f2  \f0 Resonance Analysis for Auric Replicator\\n",\par
    "\\n",\par
    "**Notebook ID:** 02-resonance-analysis\\n",\par
    "**Author:** Mark David Louise Kruger\\n",\par
    "**Date:** 2026-03-10\\n",\par
    "**Description:** LC circuit analysis, frequency response, and Q factor optimization."\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "import numpy as np\\n",\par
    "import matplotlib.pyplot as plt\\n",\par
    "from scipy import signal\\n",\par
    "import pandas as pd\\n",\par
    "\\n",\par
    "plt.style.use('seaborn-v0_8-darkgrid')\\n",\par
    "plt.rcParams['figure.figsize'] = [14, 8]\\n",\par
    "plt.rcParams['font.size'] = 12"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 1. Circuit Model\\n",\par
    "\\n",\par
    "The coil is modeled as an inductor with series resistance and parallel capacitance."\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Component values for different configurations\\n",\par
    "configs = \{\\n",\par
    "    'baseline': \{\\n",\par
    "        'L': 68e-6,  # H\\n",\par
    "        'R': 0.15,   # \f6\lang1032\'d9\\n",\par
    "        'C': 17e-9,  # F\\n",\par
    "        'C_parasitic': 5e-12,  # F\\n",\par
    "        'name': 'Baseline (24 AWG, 22 turns)'\\n",\par
    "    \},\\n",\par
    "    'optimized': \{\\n",\par
    "        'L': 45e-6,  # H\\n",\par
    "        'R': 0.09,   # \'d9 (lower due to Litz wire)\\n",\par
    "        'C': 25.5e-9, # F\\n",\par
    "        'C_parasitic': 8e-12,\\n",\par
    "        'name': 'Optimized (22 AWG Litz, 18 turns)'\\n",\par
    "    \},\\n",\par
    "    'ultimate': \{\\n",\par
    "        'L': 120e-6, # H (superconducting)\\n",\par
    "        'R': 1e-6,   # \'d9 (near zero)\\n",\par
    "        'C': 9.6e-9, # F\\n",\par
    "        'C_parasitic': 15e-12,\\n",\par
    "        'name': 'Ultimate (REBCO superconducting @77K)'\\n",\par
    "    \}\\n",\par
    "\}\\n",\par
    "\\n",\par
    "f_target = 148.5e3  # Hz\\n",\par
    "\\n",\par
    "print(\\"Resonance Verification:\\")\\n",\par
    "print(\\"-\\" * 60)\\n",\par
    "for key, cfg in configs.items():\\n",\par
    "    C_total = cfg['C'] + cfg['C_parasitic']\\n",\par
    "    f_res = 1 / (2 * np.pi * np.sqrt(cfg['L'] * C_total))\\n",\par
    "    error = abs(f_res - f_target) / f_target * 100\\n",\par
    "    print(f\\"\{key.upper()\}:\\")\\n",\par
    "    print(f\\"  L = \{cfg['L']*1e6:.2f\} \f0\lang1033\'b5H, C = \{C_total*1e9:.2f\} nF\\")\\n",\par
    "    print(f\\"  f_res = \{f_res/1000:.3f\} kHz (error: \{error:.3f\}%)\\")"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 2. Frequency Response Analysis"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Frequency sweep\\n",\par
    "f = np.linspace(100e3, 200e3, 10000)\\n",\par
    "omega = 2 * np.pi * f\\n",\par
    "\\n",\par
    "fig, axes = plt.subplots(2, 2, figsize=(16, 12))\\n",\par
    "\\n",\par
    "for idx, (key, cfg) in enumerate(configs.items()):\\n",\par
    "    ax = axes[idx // 2, idx % 2]\\n",\par
    "    \\n",\par
    "    # Impedance of parallel RLC\\n",\par
    "    Z_L = 1j * omega * cfg['L']\\n",\par
    "    Z_C = 1 / (1j * omega * (cfg['C'] + cfg['C_parasitic']))\\n",\par
    "    Z_R = cfg['R']\\n",\par
    "    \\n",\par
    "    # Parallel combination\\n",\par
    "    Z_parallel = 1 / (1/Z_L + 1/Z_C + 1/Z_R)\\n",\par
    "    \\n",\par
    "    # Magnitude and phase\\n",\par
    "    Z_mag = np.abs(Z_parallel)\\n",\par
    "    Z_phase = np.angle(Z_parallel, deg=True)\\n",\par
    "    \\n",\par
    "    # Find resonance\\n",\par
    "    f_res_idx = np.argmin(Z_mag)\\n",\par
    "    f_res = f[f_res_idx] / 1000\\n",\par
    "    Z_res = Z_mag[f_res_idx]\\n",\par
    "    \\n",\par
    "    # Q factor from -3dB bandwidth\\n",\par
    "    Z_min = Z_res\\n",\par
    "    Z_3dB = Z_min * np.sqrt(2)\\n",\par
    "    \\n",\par
    "    # Find frequencies where Z = Z_3dB\\n",\par
    "    idx_below = np.where(Z_mag[:f_res_idx] <= Z_3dB)[0]\\n",\par
    "    idx_above = np.where(Z_mag[f_res_idx:] <= Z_3dB)[0]\\n",\par
    "    \\n",\par
    "    if len(idx_below) > 0 and len(idx_above) > 0:\\n",\par
    "        f1 = f[idx_below[-1]]\\n",\par
    "        f2 = f[f_res_idx + idx_above[0]]\\n",\par
    "        bandwidth = (f2 - f1) / 1000\\n",\par
    "        Q = f_res / (bandwidth * 1000)\\n",\par
    "    else:\\n",\par
    "        Q = np.nan\\n",\par
    "    \\n",\par
    "    # Plot impedance magnitude\\n",\par
    "    ax.semilogy(f/1000, Z_mag, 'b-', linewidth=2)\\n",\par
    "    ax.axvline(x=f_target/1000, color='r', linestyle='--', alpha=0.5, label='Target 148.5 kHz')\\n",\par
    "    ax.axvline(x=f_res, color='g', linestyle='--', alpha=0.5, label=f'Resonance: \{f_res:.2f\} kHz')\\n",\par
    "    ax.plot(f_res, Z_res, 'ro', markersize=8)\\n",\par
    "    \\n",\par
    "    ax.set_xlabel('Frequency (kHz)')\\n",\par
    "    ax.set_ylabel('Impedance |Z| (\f6\lang1032\'d9)')\\n",\par
    "    ax.set_title(f'\{cfg[\\"name\\"]\}\\\\nQ = \{Q:.1f\}, f_res = \{f_res:.2f\} kHz')\\n",\par
    "    ax.legend()\\n",\par
    "    ax.grid(True, alpha=0.3)\\n",\par
    "    ax.set_xlim([100, 200])\\n",\par
    "\\n",\par
    "plt.tight_layout()\\n",\par
    "plt.savefig('../results/figures/frequency-response.png', dpi=300, bbox_inches='tight')\\n",\par
    "plt.show()"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 3. Q Factor and Bandwidth Analysis"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Calculate Q factors and bandwidths for all configurations\\n",\par
    "results = []\\n",\par
    "\\n",\par
    "for key, cfg in configs.items():\\n",\par
    "    # Theoretical Q for series RLC\\n",\par
    "    Q_theoretical = (1/cfg['R']) * np.sqrt(cfg['L'] / (cfg['C'] + cfg['C_parasitic']))\\n",\par
    "    \\n",\par
    "    # Bandwidth\\n",\par
    "    BW = f_target / Q_theoretical\\n",\par
    "    \\n",\par
    "    results.append(\{\\n",\par
    "        'Configuration': key,\\n",\par
    "        'Q_factor': Q_theoretical,\\n",\par
    "        'Bandwidth (Hz)': BW,\\n",\par
    "        'Bandwidth (kHz)': BW/1000,\\n",\par
    "        'Stability (Hz/\f0\lang1033\'b0C)': f_target * 50e-6,  # Approximate temp coefficient\\n",\par
    "    \})\\n",\par
    "\\n",\par
    "df = pd.DataFrame(results)\\n",\par
    "print(\\"Q Factor Analysis:\\")\\n",\par
    "print(df.to_string(index=False))"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 4. Temperature Stability"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Temperature coefficients\\n",\par
    "alpha_L = 100e-6  # ppm/\'b0C for copper (inductance)\\n",\par
    "alpha_C = 50e-6   # ppm/\'b0C for NP0 capacitor\\n",\par
    "alpha_R = 3900e-6 # ppm/\'b0C for copper (resistance)\\n",\par
    "\\n",\par
    "T_range = np.linspace(0, 100, 100)  # \'b0C\\n",\par
    "T_ref = 25  # \'b0C\\n",\par
    "\\n",\par
    "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\\n",\par
    "\\n",\par
    "for key, cfg in configs.items():\\n",\par
    "    # Temperature-dependent values\\n",\par
    "    L_T = cfg['L'] * (1 + alpha_L * (T_range - T_ref))\\n",\par
    "    C_T = (cfg['C'] + cfg['C_parasitic']) * (1 + alpha_C * (T_range - T_ref))\\n",\par
    "    R_T = cfg['R'] * (1 + alpha_R * (T_range - T_ref))\\n",\par
    "    \\n",\par
    "    # Resonance frequency vs temperature\\n",\par
    "    f_T = 1 / (2 * np.pi * np.sqrt(L_T * C_T))\\n",\par
    "    drift_ppm = (f_T - f_target) / f_target * 1e6\\n",\par
    "    \\n",\par
    "    axes[0].plot(T_range, drift_ppm, linewidth=2, label=cfg['name'])\\n",\par
    "    \\n",\par
    "    # Q factor vs temperature\\n",\par
    "    Q_T = (1/R_T) * np.sqrt(L_T / C_T)\\n",\par
    "    axes[1].plot(T_range, Q_T, linewidth=2, label=cfg['name'])\\n",\par
    "\\n",\par
    "axes[0].axhline(y=0, color='k', linestyle='-', alpha=0.3)\\n",\par
    "axes[0].axvline(x=T_ref, color='k', linestyle='--', alpha=0.3)\\n",\par
    "axes[0].set_xlabel('Temperature (\'b0C)')\\n",\par
    "axes[0].set_ylabel('Frequency Drift (ppm)')\\n",\par
    "axes[0].set_title('Resonance Frequency vs Temperature')\\n",\par
    "axes[0].legend()\\n",\par
    "axes[0].grid(True, alpha=0.3)\\n",\par
    "\\n",\par
    "axes[1].set_xlabel('Temperature (\'b0C)')\\n",\par
    "axes[1].set_ylabel('Q Factor')\\n",\par
    "axes[1].set_title('Q Factor vs Temperature')\\n",\par
    "axes[1].legend()\\n",\par
    "axes[1].grid(True, alpha=0.3)\\n",\par
    "\\n",\par
    "plt.tight_layout()\\n",\par
    "plt.savefig('../results/figures/temperature-stability.png', dpi=300, bbox_inches='tight')\\n",\par
    "plt.show()"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 5. Matching Network Design"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Design L-match network for 50\f6\lang1032\'d9 source\\n",\par
    "R_source = 50  # \'d9\\n",\par
    "\\n",\par
    "for key, cfg in configs.items():\\n",\par
    "    # Load impedance at resonance\\n",\par
    "    Z_load = cfg['R']  # At resonance, impedance is just resistance\\n",\par
    "    \\n",\par
    "    if Z_load < R_source:\\n",\par
    "        # Low-pass L-match\\n",\par
    "        Q = np.sqrt(R_source / Z_load - 1)\\n",\par
    "        X_L = Q * Z_load\\n",\par
    "        X_C = R_source / Q\\n",\par
    "        \\n",\par
    "        L_match = X_L / (2 * np.pi * f_target)\\n",\par
    "        C_match = 1 / (2 * np.pi * f_target * X_C)\\n",\par
    "        \\n",\par
    "        print(f\\"\\\\n\{key.upper()\} Matching Network:\\")\\n",\par
    "        print(f\\"  Topology: Low-pass L-match\\")\\n",\par
    "        print(f\\"  Q factor: \{Q:.2f\}\\")\\n",\par
    "        print(f\\"  Series L: \{L_match*1e6:.2f\} \f0\lang1033\'b5H\\")\\n",\par
    "        print(f\\"  Shunt C: \{C_match*1e9:.2f\} nF\\")\\n",\par
    "        print(f\\"  Bandwidth: \{f_target/Q/1000:.2f\} kHz\\")"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 6. Time Domain Response"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Time domain simulation\\n",\par
    "t = np.linspace(0, 100e-6, 10000)  # 100 \'b5s\\n",\par
    "f_drive = f_target\\n",\par
    "\\n",\par
    "fig, axes = plt.subplots(2, 3, figsize=(18, 10))\\n",\par
    "\\n",\par
    "for idx, (key, cfg) in enumerate(configs.items()):\\n",\par
    "    ax1 = axes[0, idx]\\n",\par
    "    ax2 = axes[1, idx]\\n",\par
    "    \\n",\par
    "    # Drive voltage\\n",\par
    "    V_drive = 10 * np.sin(2 * np.pi * f_drive * t)\\n",\par
    "    \\n",\par
    "    # Simple RLC response (approximate)\\n",\par
    "    omega0 = 2 * np.pi * f_target\\n",\par
    "    Q = (1/cfg['R']) * np.sqrt(cfg['L'] / (cfg['C'] + cfg['C_parasitic']))\\n",\par
    "    alpha = omega0 / (2 * Q)  # Damping factor\\n",\par
    "    omega_d = np.sqrt(omega0**2 - alpha**2)  # Damped frequency\\n",\par
    "    \\n",\par
    "    # Step response envelope\\n",\par
    "    envelope = 1 - np.exp(-alpha * t)\\n",\par
    "    \\n",\par
    "    ax1.plot(t*1e6, V_drive, 'b-', alpha=0.7, label='Drive')\\n",\par
    "    ax1.plot(t*1e6, envelope * 10, 'r--', label='Envelope')\\n",\par
    "    ax1.set_xlabel('Time (\'b5s)')\\n",\par
    "    ax1.set_ylabel('Voltage (V)')\\n",\par
    "    ax1.set_title(f'\{cfg[\\"name\\"]\} - Drive Signal')\\n",\par
    "    ax1.set_xlim([0, 20])\\n",\par
    "    ax1.legend()\\n",\par
    "    ax1.grid(True, alpha=0.3)\\n",\par
    "    \\n",\par
    "    # Ring-down (impulse response)\\n",\par
    "    impulse = np.exp(-alpha * t) * np.sin(omega_d * t)\\n",\par
    "    \\n",\par
    "    ax2.plot(t*1e6, impulse, 'g-', linewidth=2)\\n",\par
    "    ax2.plot(t*1e6, np.exp(-alpha * t), 'r--', label='Envelope')\\n",\par
    "    ax2.plot(t*1e6, -np.exp(-alpha * t), 'r--')\\n",\par
    "    ax2.set_xlabel('Time (\'b5s)')\\n",\par
    "    ax2.set_ylabel('Amplitude (arb)')\\n",\par
    "    ax2.set_title(f'Ring-down Response (Q=\{Q:.1f\})')\\n",\par
    "    ax2.set_xlim([0, 50])\\n",\par
    "    ax2.legend()\\n",\par
    "    ax2.grid(True, alpha=0.3)\\n",\par
    "\\n",\par
    "plt.tight_layout()\\n",\par
    "plt.savefig('../results/figures/time-domain-response.png', dpi=300, bbox_inches='tight')\\n",\par
    "plt.show()"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 7. Component Sensitivity Analysis"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Sensitivity to component variations\\n",\par
    "tolerance = np.linspace(-10, 10, 100)  # percent\\n",\par
    "\\n",\par
    "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\\n",\par
    "\\n",\par
    "for idx, (key, cfg) in enumerate(configs.items()):\\n",\par
    "    ax = axes[idx]\\n",\par
    "    \\n",\par
    "    f_nominal = 1 / (2 * np.pi * np.sqrt(cfg['L'] * (cfg['C'] + cfg['C_parasitic'])))\\n",\par
    "    \\n",\par
    "    # Vary L\\n",\par
    "    L_var = cfg['L'] * (1 + tolerance/100)\\n",\par
    "    f_L = 1 / (2 * np.pi * np.sqrt(L_var * (cfg['C'] + cfg['C_parasitic'])))\\n",\par
    "    \\n",\par
    "    # Vary C\\n",\par
    "    C_var = (cfg['C'] + cfg['C_parasitic']) * (1 + tolerance/100)\\n",\par
    "    f_C = 1 / (2 * np.pi * np.sqrt(cfg['L'] * C_var))\\n",\par
    "    \\n",\par
    "    ax.plot(tolerance, (f_L - f_nominal)/f_nominal*100, 'b-', linewidth=2, label='L variation')\\n",\par
    "    ax.plot(tolerance, (f_C - f_nominal)/f_nominal*100, 'r-', linewidth=2, label='C variation')\\n",\par
    "    ax.axhline(y=0, color='k', linestyle='-', alpha=0.3)\\n",\par
    "    ax.axvline(x=0, color='k', linestyle='-', alpha=0.3)\\n",\par
    "    \\n",\par
    "    ax.set_xlabel('Component Tolerance (%)')\\n",\par
    "    ax.set_ylabel('Frequency Error (%)')\\n",\par
    "    ax.set_title(f'\{cfg[\\"name\\"]\}')\\n",\par
    "    ax.legend()\\n",\par
    "    ax.grid(True, alpha=0.3)\\n",\par
    "\\n",\par
    "plt.tight_layout()\\n",\par
    "plt.savefig('../results/figures/sensitivity-analysis.png', dpi=300, bbox_inches='tight')\\n",\par
    "plt.show()"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 8. Optimization Results Summary"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Summary table\\n",\par
    "summary = []\\n",\par
    "\\n",\par
    "for key, cfg in configs.items():\\n",\par
    "    C_total = cfg['C'] + cfg['C_parasitic']\\n",\par
    "    f_res = 1 / (2 * np.pi * np.sqrt(cfg['L'] * C_total))\\n",\par
    "    Q = (1/cfg['R']) * np.sqrt(cfg['L'] / C_total)\\n",\par
    "    BW = f_res / Q\\n",\par
    "    \\n",\par
    "    summary.append(\{\\n",\par
    "        'Configuration': key.upper(),\\n",\par
    "        'L (\'b5H)': cfg['L']*1e6,\\n",\par
    "        'C (nF)': C_total*1e9,\\n",\par
    "        'R (m\f6\lang1032\'d9)': cfg['R']*1000,\\n",\par
    "        'f_res (kHz)': f_res/1000,\\n",\par
    "        'Q Factor': Q,\\n",\par
    "        'BW (Hz)': BW,\\n",\par
    "        'Settling Time (\f0\lang1033\'b5s)': Q / (np.pi * f_res) * 1e6\\n",\par
    "    \})\\n",\par
    "\\n",\par
    "df_summary = pd.DataFrame(summary)\\n",\par
