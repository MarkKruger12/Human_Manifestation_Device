  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 4. Field Along Center Axis"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Calculate field along center axis\\n",\par
    "z_axis = np.linspace(0, 50, 200)\\n",\par
    "Bz_axis = []\\n",\par
    "\\n",\par
    "for z in z_axis:\\n",\par
    "    _, _, Bz = total_field(0, 0, z, magnet_positions, config)\\n",\par
    "    Bz_axis.append(Bz * 10000)  # Convert to Gauss\\n",\par
    "\\n",\par
    "Bz_axis = np.array(Bz_axis)\\n",\par
    "\\n",\par
    "# Plot\\n",\par
    "fig, ax = plt.subplots(figsize=(12, 6))\\n",\par
    "\\n",\par
    "ax.plot(z_axis, Bz_axis, 'b-', linewidth=2, label='Total field')\\n",\par
    "ax.axhline(y=0, color='k', linestyle='-', alpha=0.3)\\n",\par
    "ax.axvline(x=config['magnet_thickness'], color='r', linestyle='--', label='Magnet surface')\\n",\par
    "\\n",\par
    "# Mark null point if exists\\n",\par
    "null_idx = np.where(np.diff(np.sign(Bz_axis)))[0]\\n",\par
    "if len(null_idx) > 0:\\n",\par
    "    z_null = z_axis[null_idx[0]]\\n",\par
    "    B_null = Bz_axis[null_idx[0]]\\n",\par
    "    ax.plot(z_null, B_null, 'ro', markersize=10, label=f'Null at z=\{z_null:.2f\}mm')\\n",\par
    "\\n",\par
    "ax.set_xlabel('Distance from magnet surface (mm)')\\n",\par
    "ax.set_ylabel('Bz (Gauss)')\\n",\par
    "ax.set_title('Magnetic Field Along Center Axis')\\n",\par
    "ax.legend()\\n",\par
    "ax.grid(True, alpha=0.3)\\n",\par
    "\\n",\par
    "plt.savefig('../results/figures/field-axis-profile.png', dpi=300, bbox_inches='tight')\\n",\par
    "plt.show()\\n",\par
    "\\n",\par
    "print(f\\"Field at surface: \{Bz_axis[0]:.1f\} Gauss\\")\\n",\par
    "print(f\\"Field at 25.4mm: \{Bz_axis[np.argmin(np.abs(z_axis-25.4))]:.1f\} Gauss\\")\\n",\par
    "if len(null_idx) > 0:\\n",\par
    "    print(f\\"Null point: \{z_null:.2f\} mm, \{B_null:.2f\} Gauss\\")"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 5. Null Region Analysis"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Scan null region in 3D\\n",\par
    "z_null_center = z_null if len(null_idx) > 0 else 25.0\\n",\par
    "\\n",\par
    "# XY scan at null height\\n",\par
    "x_scan = np.linspace(-10, 10, 50)\\n",\par
    "y_scan = np.linspace(-10, 10, 50)\\n",\par
    "X_null, Y_null = np.meshgrid(x_scan, y_scan)\\n",\par
    "B_null_map = np.zeros_like(X_null)\\n",\par
    "\\n",\par
    "for i in range(len(x_scan)):\\n",\par
    "    for j in range(len(y_scan)):\\n",\par
    "        _, _, Bz = total_field(X_null[i,j], Y_null[i,j], z_null_center, magnet_positions, config)\\n",\par
    "        B_null_map[i,j] = np.abs(Bz * 10000)  # Absolute value in Gauss"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Plot null region\\n",\par
    "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\\n",\par
    "\\n",\par
    "# Contour plot of null region\\n",\par
    "contour = axes[0].contourf(X_null, Y_null, B_null_map.T, levels=50, cmap='viridis')\\n",\par
    "plt.colorbar(contour, ax=axes[0], label='|B| (Gauss)')\\n",\par
    "axes[0].set_xlabel('X (mm)')\\n",\par
    "axes[0].set_ylabel('Y (mm)')\\n",\par
    "axes[0].set_title(f'Null Region at z=\{z_null_center:.2f\}mm')\\n",\par
    "axes[0].set_aspect('equal')\\n",\par
    "\\n",\par
    "# Find null diameter at half maximum\\n",\par
    "B_min = np.min(B_null_map)\\n",\par
    "B_half = B_min * 2  # Half of maximum? Actually we want FWHM\\n",\par
    "# Better: find where field > threshold\\n",\par
    "threshold = 50  # Gauss\\n",\par
    "null_mask = B_null_map < threshold\\n",\par
    "\\n",\par
    "from scipy import ndimage\\n",\par
    "labeled, num_features = ndimage.label(null_mask)\\n",\par
    "if num_features > 0:\\n",\par
    "    sizes = ndimage.sum(null_mask, labeled, range(1, num_features+1))\\n",\par
    "    max_label = np.argmax(sizes) + 1\\n",\par
    "    main_null = (labeled == max_label)\\n",\par
    "    \\n",\par
    "    # Find bounding box\\n",\par
    "    rows = np.any(main_null, axis=1)\\n",\par
    "    cols = np.any(main_null, axis=0)\\n",\par
    "    rmin, rmax = np.where(rows)[0][[0, -1]]\\n",\par
    "    cmin, cmax = np.where(cols)[0][[0, -1]]\\n",\par
    "    \\n",\par
    "    null_width = (x_scan[rmax] - x_scan[rmin])\\n",\par
    "    null_height = (y_scan[cmax] - y_scan[cmin])\\n",\par
    "    \\n",\par
    "    # Draw bounding box\\n",\par
    "    rect = plt.Rectangle((x_scan[rmin], y_scan[cmin]), \\n",\par
    "                         null_width, null_height,\\n",\par
    "                         fill=False, edgecolor='red', linewidth=2)\\n",\par
    "    axes[0].add_patch(rect)\\n",\par
    "    axes[0].text(x_scan[rmin], y_scan[cmin]-1, \\n",\par
    "                f'\{null_width:.2f\}mm \'d7 \{null_height:.2f\}mm',\\n",\par
    "                color='red', fontweight='bold')\\n",\par
    "\\n",\par
    "# Radial profile\\n",\par
    "r_profile = np.linspace(0, 10, 100)\\n",\par
    "B_profile = []\\n",\par
    "for r in r_profile:\\n",\par
    "    _, _, Bz = total_field(r, 0, z_null_center, magnet_positions, config)\\n",\par
    "    B_profile.append(np.abs(Bz * 10000))\\n",\par
    "\\n",\par
    "axes[1].plot(r_profile, B_profile, 'b-', linewidth=2)\\n",\par
    "axes[1].axhline(y=threshold, color='r', linestyle='--', label=f'\{threshold\} Gauss threshold')\\n",\par
    "axes[1].set_xlabel('Radial distance (mm)')\\n",\par
    "axes[1].set_ylabel('|B| (Gauss)')\\n",\par
    "axes[1].set_title('Radial Profile of Null Region')\\n",\par
    "axes[1].legend()\\n",\par
    "axes[1].grid(True, alpha=0.3)\\n",\par
    "\\n",\par
    "plt.tight_layout()\\n",\par
    "plt.savefig('../results/figures/null-region-analysis.png', dpi=300, bbox_inches='tight')\\n",\par
    "plt.show()\\n",\par
    "\\n",\par
    "if num_features > 0:\\n",\par
    "    print(f\\"Null region size: \{null_width:.2f\}mm \'d7 \{null_height:.2f\}mm\\")\\n",\par
    "    print(f\\"Minimum field: \{B_min:.2f\} Gauss\\")"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 6. Coil Field Contribution"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "def solenoid_field(x, y, z, R, L, N, I, turns_per_length=None):\\n",\par
    "    \\"\\"\\"\\n",\par
    "    Calculate field from solenoid at point (x,y,z).\\n",\par
    "    \\n",\par
    "    Parameters:\\n",\par
    "    -----------\\n",\par
    "    R : solenoid radius (mm)\\n",\par
    "    L : solenoid length (mm)\\n",\par
    "    N : number of turns\\n",\par
    "    I : current (A)\\n",\par
    "    \\"\\"\\"\\n",\par
    "    # Convert to meters\\n",\par
    "    x = x / 1000\\n",\par
    "    y = y / 1000\\n",\par
    "    z = z / 1000\\n",\par
    "    R = R / 1000\\n",\par
    "    L = L / 1000\\n",\par
    "    \\n",\par
    "    mu0 = 4*np.pi*1e-7\\n",\par
    "    n = N / L  # turns per meter\\n",\par
    "    \\n",\par
    "    # Cylindrical coordinates\\n",\par
    "    rho = np.sqrt(x**2 + y**2)\\n",\par
    "    \\n",\par
    "    # On-axis\\n",\par
    "    if rho < 1e-10:\\n",\par
    "        z1 = z - L/2\\n",\par
    "        z2 = z + L/2\\n",\par
    "        Bz = (mu0 * n * I / 2) * ((z2)/np.sqrt(z2**2 + R**2) - (z1)/np.sqrt(z1**2 + R**2))\\n",\par
    "        return 0, 0, Bz\\n",\par
    "    \\n",\par
    "    # Off-axis (approximate using elliptic integrals)\\n",\par
    "    # For simplicity, return on-axis approximation scaled by geometry\\n",\par
    "    # Accurate calculation would require integration\\n",\par
    "    z1 = z - L/2\\n",\par
    "    z2 = z + L/2\\n",\par
    "    \\n",\par
    "    alpha1 = R / np.sqrt(z1**2 + (R + rho)**2)\\n",\par
    "    alpha2 = R / np.sqrt(z2**2 + (R + rho)**2)\\n",\par
    "    \\n",\par
    "    beta1 = z1 / np.sqrt(z1**2 + (R + rho)**2)\\n",\par
    "    beta2 = z2 / np.sqrt(z2**2 + (R + rho)**2)\\n",\par
    "    \\n",\par
    "    gamma = (R - rho) / (R + rho)\\n",\par
    "    \\n",\par
    "    from scipy.special import ellipk, ellipe\\n",\par
    "    \\n",\par
    "    k_sq = 4*R*rho / ((R + rho)**2 + z**2)\\n",\par
    "    k_sq = np.clip(k_sq, 0, 0.9999)\\n",\par
    "    \\n",\par
    "    K = ellipk(k_sq)\\n",\par
    "    E = ellipe(k_sq)\\n",\par
    "    \\n",\par
    "    B_phi = 0  # azimuthal component zero for ideal solenoid\\n",\par
    "    \\n",\par
    "    B_rho = (mu0 * n * I * R) / (np.pi * np.sqrt((R + rho)**2 + z**2)) * (\\n",\par
    "        (K - E * (1 - k_sq/2) / (1 - k_sq)) / (R - rho)\\n",\par
    "    )\\n",\par
    "    \\n",\par
    "    Bz = (mu0 * n * I) / (2 * np.pi * np.sqrt((R + rho)**2 + z**2)) * (\\n",\par
    "        K + (R**2 - rho**2 - z**2) * E / ((R - rho)**2 + z**2)\\n",\par
    "    )\\n",\par
    "    \\n",\par
    "    # Convert to Cartesian\\n",\par
    "    if rho > 0:\\n",\par
    "        Bx = B_rho * (x/rho)\\n",\par
    "        By = B_rho * (y/rho)\\n",\par
    "    else:\\n",\par
    "        Bx = 0\\n",\par
    "        By = 0\\n",\par
    "    \\n",\par
    "    return Bx, By, Bz"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Calculate total field including coil\\n",\par
    "def total_field_with_coil(x, y, z, magnet_positions, config, coil_current):\\n",\par
    "    # Magnet field\\n",\par
    "    Bx_m, By_m, Bz_m = total_field(x, y, z, magnet_positions, config)\\n",\par
    "    \\n",\par
    "    # Coil field\\n",\par
    "    coil_R = config['coil_od'] / 2\\n",\par
    "    coil_L = 25.4  # mm (coil length)\\n",\par
    "    Bx_c, By_c, Bz_c = solenoid_field(x, y, z, coil_R, coil_L, \\n",\par
    "                                      config['coil_turns'], coil_current)\\n",\par
    "    \\n",\par
    "    return Bx_m + Bx_c, By_m + By_c, Bz_m + Bz_c"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Scan current to find null condition\\n",\par
    "currents = np.linspace(0, 6, 50)\\n",\par
    "B_center = []\\n",\par
    "\\n",\par
    "for I in currents:\\n",\par
    "    _, _, Bz = total_field_with_coil(0, 0, z_null_center, magnet_positions, config, I)\\n",\par
    "    B_center.append(np.abs(Bz * 10000))\\n",\par
    "\\n",\par
    "B_center = np.array(B_center)\\n",\par
    "\\n",\par
    "# Find minimum\\n",\par
    "I_opt = currents[np.argmin(B_center)]\\n",\par
    "B_min = np.min(B_center)\\n",\par
    "\\n",\par
    "# Plot\\n",\par
    "fig, ax = plt.subplots(figsize=(12, 6))\\n",\par
    "\\n",\par
    "ax.plot(currents, B_center, 'b-', linewidth=2)\\n",\par
    "ax.plot(I_opt, B_min, 'ro', markersize=10, label=f'Optimum: \{I_opt:.2f\}A, \{B_min:.2f\}G')\\n",\par
    "ax.set_xlabel('Coil Current (A)')\\n",\par
    "ax.set_ylabel('|B| at Center (Gauss)')\\n",\par
    "ax.set_title('Null Optimization - Current Sweep')\\n",\par
    "ax.legend()\\n",\par
    "ax.grid(True, alpha=0.3)\\n",\par
    "\\n",\par
    "plt.savefig('../results/figures/current-sweep-optimization.png', dpi=300, bbox_inches='tight')\\n",\par
    "plt.show()\\n",\par
    "\\n",\par
    "print(f\\"Optimum current: \{I_opt:.2f\} A\\")\\n",\par
    "print(f\\"Minimum field: \{B_min:.2f\} Gauss\\")\\n",\par
    "print(f\\"Reduction factor: \{B_center[0]/B_min:.1f\}x\\")"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "markdown",\par
   "metadata": \{\},\par
   "source": [\par
    "## 7. Patent Claim Verification"\par
   ]\par
  \},\par
  \{\par
   "cell_type": "code",\par
   "execution_count": null,\par
   "metadata": \{\},\par
   "source": [\par
    "# Verify patent claims\\n",\par
