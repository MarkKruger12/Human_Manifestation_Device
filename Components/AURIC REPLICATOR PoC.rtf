femm.mi_addblocklabel(19.05, 0)\par
femm.mi_selectlabel(19.05, 0)\par
femm.mi_setblockprop('Copper', 0, 0, 0, 0, 0, 0)\par
femm.mi_clearselected()\par
\par
# Add circuit (coil)\par
femm.mi_addcircuit('Coil', 1)\par
femm.mi_selectcircuit('Coil')\par
femm.mi_setcircuitprops('Coil', 5, 0)  # 5A peak\par
\par
# Analyze\par
femm.mi_analyze()\par
femm.mi_loadsolution()\par
\par
# Extract B-field along centerline\par
z = np.linspace(0, 50, 100)\par
Bz = []\par
\par
for zi in z:\par
    B = femm.mo_getb(0, zi)\par
    Bz.append(B[1])  # z-component\par
\par
# Plot\par
plt.figure(figsize=(10, 6))\par
plt.plot(z, Bz)\par
plt.xlabel('Distance from center (mm)')\par
plt.ylabel('B-field (Tesla)')\par
plt.title('Magnetic Field Along Center Axis')\par
plt.grid(True)\par
plt.savefig('B_field_simulation.png')\par
