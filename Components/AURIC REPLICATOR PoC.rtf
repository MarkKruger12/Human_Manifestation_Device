### 15.4 Appendix B: Control System Arduino Sketch\par
\par
```cpp\par
// Auric Replicator - Basic Control System\par
// For Arduino Nano / STM32\par
\par
#include <Wire.h>\par
#include <Adafruit_MCP4725.h>\par
\par
// Pin definitions\par
#define PWM_PIN 9\par
#define CURRENT_SENSE_PIN A0\par
#define VOLTAGE_SENSE_PIN A1\par
#define HALL_SENSE_PIN A2\par
#define TEMP_SENSE_PIN A3\par
#define ENC_A_PIN 2\par
#define ENC_B_PIN 3\par
#define BUTTON_PIN 4\par
#define LED_PIN 13\par
\par
// Constants\par
const float TARGET_FREQ = 148500.0;  // Hz\par
const float FREQ_STEP = 10.0;  // Hz\par
const float MAX_CURRENT = 5.0;  // A\par
const float MIN_CURRENT = 0.5;  // A\par
\par
// Global variables\par
float current_freq = TARGET_FREQ;\par
float current_current = 2.5;\par
bool auto_tune = true;\par
int encoder_pos = 0;\par
\par
// DAC for frequency control (if using external VCO)\par
Adafruit_MCP4725 dac;\par
\par
void setup() \{\par
  Serial.begin(115200);\par
  \par
  // Initialize pins\par
  pinMode(PWM_PIN, OUTPUT);\par
  pinMode(ENC_A_PIN, INPUT_PULLUP);\par
  pinMode(ENC_B_PIN, INPUT_PULLUP);\par
  pinMode(BUTTON_PIN, INPUT_PULLUP);\par
  pinMode(LED_PIN, OUTPUT);\par
  \par
  // Initialize DAC\par
  dac.begin(0x60);\par
  \par
  // Set initial frequency\par
  setFrequency(TARGET_FREQ);\par
  \par
  // Attach interrupts for encoder\par
  attachInterrupt(digitalPinToInterrupt(ENC_A_PIN), encoderISR, CHANGE);\par
  \par
  Serial.println("Auric Replicator Control System");\par
  Serial.println("Ready");\par
\}\par
\par
void loop() \{\par
  // Read sensors\par
  float current = readCurrent();\par
  float voltage = readVoltage();\par
  float hall = readHall();\par
  float temperature = readTemperature();\par
  \par
  // Auto-tuning algorithm\par
  if (auto_tune) \{\par
    float phase = measurePhase();\par
    if (phase > 0.1) \{\par
      current_freq += FREQ_STEP * 0.1;\par
    \} else if (phase < -0.1) \{\par
      current_freq -= FREQ_STEP * 0.1;\par
    \}\par
    setFrequency(current_freq);\par
  \}\par
  \par
  // Check for button press\par
  if (digitalRead(BUTTON_PIN) == LOW) \{\par
    auto_tune = !auto_tune;\par
    digitalWrite(LED_PIN, auto_tune ? HIGH : LOW);\par
    delay(500);  // Debounce\par
  \}\par
  \par
  // Serial output\par
  Serial.print(current_freq);\par
  Serial.print(",");\par
  Serial.print(current);\par
  Serial.print(",");\par
  Serial.print(hall);\par
  Serial.print(",");\par
  Serial.println(temperature);\par
  \par
  delay(100);  // 10 Hz update\par
\}\par
\par
void setFrequency(float freq) \{\par
  // For DDS or VCO control via DAC\par
  float dac_value = (freq - 100000.0) / 100000.0 * 4095.0;\par
  dac_value = constrain(dac_value, 0, 4095);\par
  dac.setOutput(dac_value);\par
  \par
  // Alternative: PWM frequency\par
  // analogWriteFrequency(PWM_PIN, freq);\par
\}\par
\par
float readCurrent() \{\par
  int raw = analogRead(CURRENT_SENSE_PIN);\par
  return raw * (5.0 / 1023.0) * 2.0;  // Convert to amps\par
\}\par
\par
float readVoltage() \{\par
  int raw = analogRead(VOLTAGE_SENSE_PIN);\par
  return raw * (5.0 / 1023.0) * 25.0;  // Convert to volts\par
\}\par
\par
float readHall() \{\par
  int raw = analogRead(HALL_SENSE_PIN);\par
  return (raw - 512) * (5.0 / 1023.0) * 1000.0;  // Convert to Gauss\par
\}\par
\par
float readTemperature() \{\par
  int raw = analogRead(TEMP_SENSE_PIN);\par
  // Assuming 10k NTC thermistor with 10k series resistor\par
  float resistance = 10000.0 * (1023.0 / raw - 1.0);\par
  // Steinhart-Hart equation\par
  float tempK = 1.0 / (0.001129148 + 0.000234125 * log(resistance) + \par
               0.0000000876741 * pow(log(resistance), 3));\par
  return tempK - 273.15;  // Convert to Celsius\par
\}\par
\par
float measurePhase() \{\par
  // Simplified phase measurement\par
  // In practice, use zero-crossing detection\par
  static unsigned long last_time = 0;\par
  static float last_current = 0;\par
  \par
  float current_now = readCurrent();\par
  unsigned long time_now = micros();\par
  \par
  if (last_current < 0 && current_now > 0) \{\par
    // Zero crossing detected\par
    unsigned long period = time_now - last_time;\par
    last_time = time_now;\par
    \par
    float measured_freq = 1000000.0 / period;\par
    return (measured_freq - current_freq) / current_freq;\par
  \}\par
  \par
  last_current = current_now;\par
  return 0;\par
\}\par
\par
void encoderISR() \{\par
  static int last_state = 0;\par
  int state = (digitalRead(ENC_A_PIN) << 1) | digitalRead(ENC_B_PIN);\par
  \par
  if (state != last_state) \{\par
    if (state == 0b01 && last_state == 0b00) encoder_pos++;\par
    if (state == 0b10 && last_state == 0b00) encoder_pos--;\par
    \par
    current_freq = TARGET_FREQ + encoder_pos * FREQ_STEP;\par
    setFrequency(current_freq);\par
    \par
    last_state = state;\par
  \}\par
\}\par
```\par
